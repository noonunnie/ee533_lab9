sub verify_dmem {
   print "=== Verifying Data Memory ===\n";
   set_cpu_power(0);
   foreach my $addr (0, 1, 10, 11, 20, 21, 30, 31, 32, 40) {
      read_mem($addr);
   }
}

sub usage {
   print "Usage: idsreg <cmd> <cmd options>\n";
   print "  Commands:\n";
   print "    power <0|1>             Set CPU Power (1=Run, 0=Freeze)\n";
   print "    read <addr>             Read 64-bit from data memory\n";
   print "    write_imem <addr> <hex> Write 32-bit instruction\n";
   print "    write_dmem <addr> <hi> <lo>  Write 64-bit to data_mem\n";
   print "    write_rf <addr> <hi> <lo>    Write 64-bit to regfiles\n";
   print "    load                    Load all memories\n";
   print "    verify                  Read back data memory\n";
   print "    allregs                 Dump all register values\n";
}


my $numargs = $#ARGV + 1;
if( $numargs < 1 ) {
   usage();
   exit(1);
}

my $cmd = $ARGV[0];

sub parse_val {
    my $v = shift;
    if ($v =~ /^0x/i) { return hex($v); }
    return int($v);
}

if ($cmd eq "power") {
   if ($numargs < 2) { usage(); exit(1); }
   set_cpu_power(parse_val($ARGV[1]));

} elsif ($cmd eq "read") {
   if ($numargs < 2) { usage(); exit(1); }
   read_mem(parse_val($ARGV[1]));

} elsif ($cmd eq "write_imem") {
   if ($numargs < 3) { usage(); exit(1); }
   set_cpu_power(0);
   write_imem(parse_val($ARGV[1]), parse_val($ARGV[2]));

} elsif ($cmd eq "write_dmem") {
   if ($numargs < 4) { usage(); exit(1); }
   set_cpu_power(0);
   write_dmem(parse_val($ARGV[1]), parse_val($ARGV[2]), parse_val($ARGV[3]));

} elsif ($cmd eq "write_rf") {
   if ($numargs < 4) { usage(); exit(1); }
   set_cpu_power(0);
   write_regfile(parse_val($ARGV[1]), parse_val($ARGV[2]), parse_val($ARGV[3]));

} elsif ($cmd eq "load") {
   load_all();

} elsif ($cmd eq "verify") {
   verify_dmem();

} elsif ($cmd eq "allregs") {
   printf("--- Current Register Status ---\n");
   printf("CPU_POWER_REG:       0x%08x\n", regread($IDS_CPU_POWER_REG));
   printf("HOST_ADDR_REG:       0x%08x\n", regread($IDS_HOST_ADDR_REG));
   printf("HOST_WR_ADDR_REG:    0x%08x\n", regread($IDS_HOST_WR_ADDR_REG));
   printf("HOST_WR_DATA_REG:    0x%08x\n", regread($IDS_HOST_WR_DATA_REG));
   printf("HOST_WR_CTRL_REG:    0x%08x\n", regread($IDS_HOST_WR_CTRL_REG));
   printf("HOST_RDATA_LOW_REG:  0x%08x\n", regread($IDS_HOST_RDATA_LOW_REG));
   printf("HOST_RDATA_HIGH_REG: 0x%08x\n", regread($IDS_HOST_RDATA_HIGH_REG));

} else {
   print "Unrecognized command $cmd\n";
   usage();
   exit(1);
}
