#!/usr/bin/perl -w
# Usage: ./idsreg <cmd> [options]

use lib "/usr/local/netfpga/lib/Perl5";
use strict;

# ============================================================
# Register addresses (5 SW regs + 3 HW regs)
# ============================================================
my $BASE = 0x2000300;

# Software registers
my $IDS_CPU_POWER_REG       = $BASE + 0x00;
my $IDS_HOST_ADDR_REG       = $BASE + 0x04;  # read address
my $IDS_HOST_WR_ADDR_REG    = $BASE + 0x08;  # write address
my $IDS_HOST_WR_DATA_REG    = $BASE + 0x0C;  # write data (32-bit)
my $IDS_HOST_WR_CTRL_REG    = $BASE + 0x10;  # write trigger

# Hardware registers
my $IDS_HOST_RDATA_LOW_REG  = $BASE + 0x14;
my $IDS_HOST_RDATA_HIGH_REG = $BASE + 0x18;


sub regwrite {
   my( $addr, $value ) = @_;
   my $cmd = sprintf( "regwrite 0x%08x 0x%08x", $addr, $value );
   my $result = `$cmd`;
}

sub regread {
   my( $addr ) = @_;
   my $cmd = sprintf( "regread 0x%08x", $addr );
   my @out = `$cmd`;
   my $result = $out[0];
   if ( defined $result && $result =~ m/Reg (0x[0-9a-f]+) \((\d+)\):\s+(0x[0-9a-f]+) \((\d+)\)/ ) {
      $result = $3;
   } else {
      $result = "0x00000000";
   }
   return hex($result);
}


sub set_cpu_power {
   my ($state) = @_;
   print "Setting CPU Power to: $state\n";
   regwrite($IDS_CPU_POWER_REG, $state);
}

# Trigger: write ctrl value, then immediately reset to 0
sub trigger {
   my ($ctrl_val) = @_;
   regwrite($IDS_HOST_WR_CTRL_REG, $ctrl_val);
   regwrite($IDS_HOST_WR_CTRL_REG, 0);
}

# ============================================================
# Write inst_mem (32-bit): ctrl=1
# ============================================================
sub write_imem {
   my ($addr, $instr) = @_;
   printf("  IMEM[%3d] <= 0x%08x\n", $addr, $instr);
   regwrite($IDS_HOST_WR_ADDR_REG, $addr);
   regwrite($IDS_HOST_WR_DATA_REG, $instr);
   trigger(1);
}

# ============================================================
# Write data_mem (64-bit):
#   Step 1: set data=low_half, trigger(2) -> latch into dmem_low_buf
#   Step 2: set data=high_half, trigger(3) -> write {high, latched_low}
# ============================================================
sub write_dmem {
   my ($addr, $data_high, $data_low) = @_;
   printf("  DMEM[%3d] <= 0x%08x_%08x\n", $addr, $data_high, $data_low);
   regwrite($IDS_HOST_WR_ADDR_REG, $addr);
   regwrite($IDS_HOST_WR_DATA_REG, $data_low);
   trigger(2);
   regwrite($IDS_HOST_WR_DATA_REG, $data_high);
   trigger(3);
}

# ============================================================
# Write regfile (64-bit):
#   Step 1: set data=low_half, trigger(4) -> latch into rf_low_buf
#   Step 2: set data=high_half, trigger(5) -> write {high, latched_low}
# ============================================================
sub write_regfile {
   my ($addr, $data_high, $data_low) = @_;
   printf("  RF[%2d]    <= 0x%08x_%08x\n", $addr, $data_high, $data_low);
   regwrite($IDS_HOST_WR_ADDR_REG, $addr);
   regwrite($IDS_HOST_WR_DATA_REG, $data_low);
   trigger(4);
   regwrite($IDS_HOST_WR_DATA_REG, $data_high);
   trigger(5);
}

# ============================================================
# Read data_mem
# ============================================================
sub read_mem {
   my ($addr) = @_;
   regwrite($IDS_HOST_ADDR_REG, $addr);
   my $val_low  = regread($IDS_HOST_RDATA_LOW_REG);
   my $val_high = regread($IDS_HOST_RDATA_HIGH_REG);
   printf("Read Mem: Addr 0x%08x => Data 0x%08x_%08x\n", $addr, $val_high, $val_low);
   return ($val_high, $val_low);
}

# ============================================================
# Load all memory contents
# ============================================================
