<?xml version="1.0" encoding="UTF-8"?>
<nf:module xmlns:nf="http://www.NetFPGA.org/NF2_register_system" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.NetFPGA.org/NF2_register_system NF2_register_system.xsd ">
	<nf:name>ids</nf:name>
	<nf:prefix>ids</nf:prefix>
	<nf:location>udp</nf:location>
	<nf:description>Registers for IDS</nf:description>
	<nf:blocksize>64</nf:blocksize>
	<nf:registers>
		<nf:register>
		  <nf:name>cpu_power</nf:name>
			<nf:description>1 to run CPU, 0 to freeze</nf:description>
			<nf:type>generic_software32</nf:type>
		</nf:register>
		<nf:register>
		  <nf:name>host_addr</nf:name>
			<nf:description>Target address for host read from data memory</nf:description>
			<nf:type>generic_software32</nf:type>
		</nf:register>
		<nf:register>
		  <nf:name>host_wr_addr</nf:name>
			<nf:description>Target address for host write</nf:description>
			<nf:type>generic_software32</nf:type>
		</nf:register>
		<nf:register>
		  <nf:name>host_wr_data</nf:name>
			<nf:description>32-bit data for host write</nf:description>
			<nf:type>generic_software32</nf:type>
		</nf:register>
		<nf:register>
		  <nf:name>host_wr_ctrl</nf:name>
			<nf:description>Write trigger: 0=idle, 1=imem, 2=dmem_lo, 3=dmem_hi+write, 4=rf_lo, 5=rf_hi+write</nf:description>
			<nf:type>generic_software32</nf:type>
		</nf:register>
		<nf:register>
		  <nf:name>host_rdata_low</nf:name>
			<nf:description>Lower 32 bits of returned data</nf:description>
			<nf:type>generic_hardware32</nf:type>
		</nf:register>
		<nf:register>
		  <nf:name>host_rdata_high</nf:name>
			<nf:description>Upper 32 bits of returned data</nf:description>
			<nf:type>generic_hardware32</nf:type>
		</nf:register>
	</nf:registers>
</nf:module>